{
  "manifest_version": 3,
  "name": "Acelerador de descargas by Edouard",
  "version": "1.3",
  "permissions": [
    "downloads",
    "storage",
    "cookies",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "descargas16x16.png",
      "32": "descargas32x32.png",
      "48": "descargas64x64.png"
    }
  },
  "icons": {
    "16": "descargas16x16.png",
    "32": "descargas32x32.png",
    "48": "descargas64x64.png"
  }
}
